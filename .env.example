# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://yourdomain.com
LOG_LEVEL=log

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/market_place_db
DATABASE_SSL=true
DATABASE_POOL_MAX=20

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── OTP / Auth ────────────────────────────────────────────────────────────────
# Deprecated and non-authoritative for admin auth; kept for backward compatibility.
ADMIN_PHONES=
ADMIN_PHONE=+201000000000
ADMIN_PASSWORD=ChangeMe123
OTP_PROVIDER=console
OTP_TTL_MINUTES=10
OTP_DEV_MODE=false
OTP_SIGNING_SECRET=change_this_otp_signing_secret

# ── Twilio (required when OTP_PROVIDER=twilio) ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Set exactly one of the two below (mutually exclusive):
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=cloudinary
STORAGE_BUCKET=market-media
STORAGE_PUBLIC_BASE_URL=https://your-cdn.example.com  # Not used for Cloudinary; read URLs are derived from CLOUDINARY_CLOUD_NAME + MIME type at runtime
STORAGE_UPLOAD_TTL_SECONDS=600
STORAGE_SIGNING_SECRET=change_this_storage_signing_secret

# ── Cloudinary (required when STORAGE_PROVIDER=cloudinary) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Seeder Runtime (optional; used by scripts/seed-dev.ts) ──────────────────
BASE_URL=http://localhost
SEED_PROFILE=medium
SEED_TIMEOUT_MS=12000
