{
  "name": "market_place_backend",
  "version": "1.0.0",
  "private": true,
  "description": "Online Market backend (NestJS + PostgreSQL)",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.scripts.json",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "check:src-artifacts": "bash scripts/check-no-compiled-in-src.sh",
    "ci:verify": "npm run lint && npm test && npm run check:src-artifacts",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:validate": "psql \"$DATABASE_URL\" -f db/validate.sql",
    "db:migrate": "bash scripts/migrate.sh",
    "db:migrate:dry-run": "bash scripts/migrate.sh --dry-run",
    "seed:admin": "ts-node --transpile-only scripts/seed-admin.ts",
    "seed:admin:prod": "node dist/scripts/seed-admin.js",
    "seed:dev": "ts-node --transpile-only scripts/seed-dev.ts",
    "seed:dev:prod": "node dist/scripts/seed-dev.js",
    "simulate": "ts-node --transpile-only scripts/simulate-flows.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.37.0",
    "jest": "^30.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
